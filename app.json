{
  "expo": {
    "name": "GRIT",
    "slug": "grit-app",
    "owner": "jitosz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "grit",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.grit.app",
      "config": {
        "googleMapsApiKey": "AIzaSyCj1_xDHItQl4rwp-wFG5CMRaZ4x3ibjz8"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "GRIT needs your location to track runs with GPS precision.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "GRIT needs background location to track your run even when the app is in the background."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.grit.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCj1_xDHItQl4rwp-wFG5CMRaZ4x3ibjz8"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "GRIT needs your location to track runs."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bfbf0fa7-7e76-45a1-85d3-be31a7c6aa11"
      }
    }
  }
}
